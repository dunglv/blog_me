RewriteEngine On
RewriteBase /
RewriteRule ^article/?$ index.php?section=blog
RewriteRule ^tag/?$ index.php?section=tag
RewriteRule ^404/?$ index.php?section=404
RewriteRule ^article/([a-zA-Z0-9_-]+)/?$ index.php?section=detail&url=$1
RewriteRule ^article/more/?$ index.php?section=post-more


RewriteRule ^administrator$ /admin/index.php
RewriteRule ^administrator/$ /admin/index.php

RewriteRule ^administrator/page/([0-9]+)$ admin/index.php?page=$1

RewriteRule ^administrator/login$ /admin/auth/login.php
RewriteRule ^administrator/check-login$ /admin/auth/checkLogin.php
RewriteRule ^administrator/create/?$ /admin/index.php?action=create
RewriteRule ^administrator/post/add/?$ /admin/index.php?action=add


RewriteRule ^administrator/post/([0-9]+)/delete$ /admin/index.php?post=$1&action=post-delete
RewriteRule ^administrator/ajax/post/post-delete-list$ /admin/partials/post-delete-list.php
#RewriteRule ^administrator/post/([0-9]+)/destroy$ /admin/partials/post-delete.php?action=delete&post=$1

RewriteRule ^administrator/post/([0-9]+)/edit$ /admin/index.php?action=post-edit&post=$1
RewriteRule ^administrator/post/([0-9]+)/update$ /admin/partials/post-update.php
RewriteRule ^administrator/post/([0-9]+)/update/$ /admin/partials/post-update.php
#RewriteRule ^administrator/post/([0-9_-]+)/update$ /admin/partials/editpost.php?action=delete&post=$1
